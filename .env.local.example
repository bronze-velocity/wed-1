# SMTP credentials for the contact form (POST /api/contact)
# Copy this file to .env.local and fill in your values.
#
# DEV: If you leave the SMTP_* vars blank in development, the contact form
# still works — sendMail() logs each submission to your terminal instead of
# sending a real email. Fill these in only when you want real delivery locally.
# This fallback is DISABLED in production (see pre-launch.md).

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password

# Address that receives the contact form submissions
CONTACT_EMAIL_TO=you@example.com
